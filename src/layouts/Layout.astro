---
const { 
  title = 'Remates BiPro',
  description = 'Alternativa moderna, transparente y profesional en remates y gestión de bienes en Chile.',
  ogImage = '',
  canonical = ''
} = Astro.props;
const base = import.meta.env.BASE_URL;
const fullTitle = title.includes('Remates BiPro') ? title : `${title} | Remates BiPro`;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <script is:inline>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#012A6C',
            dark:    '#011f52',
            accent:  '#F05A1A',
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', 'Segoe UI', Arial, sans-serif; }

    /* Cards */
    .remate-card { transition: transform 0.22s, box-shadow 0.22s; }
    .remate-card:hover { transform: translateY(-5px); box-shadow: 0 20px 40px rgba(19,75,152,0.12); }
    .remate-card:hover .card-img { transform: scale(1.04); }
    .card-img { transition: transform 0.4s ease; }

    /* Meta icons */
    .meta-icon { display:inline-flex; align-items:center; gap:4px; }
    .meta-icon svg { width:13px; height:13px; flex-shrink:0; }

    /* Orange underline on nav hover */
    .nav-link { position:relative; }
    .nav-link::after { content:''; position:absolute; bottom:-2px; left:50%; right:50%; height:2px; background:#F05A1A; transition: left 0.2s, right 0.2s; border-radius:2px; }
    .nav-link:hover::after { left:8px; right:8px; }

    /* Pulse badge for live auctions */
    @keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.6;transform:scale(1.4)} }
    .live-dot { animation: pulse-dot 1.5s ease-in-out infinite; }

    /* Price tag */
    .price-tag { background: linear-gradient(135deg, #F05A1A 0%, #d44710 100%); }
  </style>
</head>
<body class="bg-gray-50 text-gray-800">

  <!-- TOP BAR -->
  <div class="bg-primary text-white text-xs py-2 hidden md:block">
    <div class="max-w-7xl mx-auto px-5 flex items-center justify-between">
      <span class="flex items-center gap-2">
        <span class="live-dot inline-block w-2 h-2 rounded-full bg-accent"></span>
        Remates activos disponibles — Inscríbete hoy
      </span>
      <span class="flex items-center gap-3">
        <span class="text-white/70">contacto@rematesbipro.cl &nbsp;·&nbsp; Chile</span>
        <a href="https://www.instagram.com/rematesbipro/" target="_blank" rel="noopener" aria-label="Instagram" class="text-white/70 hover:text-accent transition">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><path d="M17.5 6.5h.01"/></svg>
        </a>
      </span>
    </div>
  </div>

  <!-- NAVBAR -->
  <header class="bg-white sticky top-0 z-50 shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-5 flex items-center justify-between h-18 py-2">
      <a href={base}>
        <img src={`${base}/bipro-logo.svg`} alt="Remates BiPro" class="h-14 md:h-16 w-auto" />
      </a>
      <nav class="hidden md:flex items-center gap-0 ml-auto">
        <a href={`${base}/vehiculos`}   class="nav-link text-gray-600 hover:text-primary px-4 py-2 text-sm font-medium transition uppercase tracking-wide">Vehículos</a>
        <a href={`${base}/propiedades`} class="nav-link text-gray-600 hover:text-primary px-4 py-2 text-sm font-medium transition uppercase tracking-wide">Propiedades</a>
        <a href={`${base}/otros`}       class="nav-link text-gray-600 hover:text-primary px-4 py-2 text-sm font-medium transition uppercase tracking-wide">Otros</a>
        <a href={`${base}/nosotros`}    class="nav-link text-gray-600 hover:text-primary px-4 py-2 text-sm font-medium transition uppercase tracking-wide">Nosotros</a>
        <a href={`${base}/contacto`}    class="nav-link text-gray-600 hover:text-primary px-4 py-2 text-sm font-medium transition uppercase tracking-wide">Contacto</a>
      </nav>
      <div class="flex items-center gap-3">
        <button id="menu-btn" class="md:hidden flex flex-col justify-center items-center w-10 h-10 rounded-xl hover:bg-gray-100 transition" aria-label="Menú">
          <span class="ham-line block w-5 h-0.5 bg-gray-700 transition-all duration-300"></span>
          <span class="ham-line block w-5 h-0.5 bg-gray-700 mt-1.5 transition-all duration-300"></span>
          <span class="ham-line block w-5 h-0.5 bg-gray-700 mt-1.5 transition-all duration-300"></span>
        </button>
      </div>
    </div>

    <!-- Menú móvil -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-5 pb-5 pt-3 flex flex-col gap-1">
      <a href={`${base}/vehiculos`}   class="text-gray-700 hover:text-primary hover:bg-gray-50 px-3 py-3 rounded-xl text-sm font-medium transition">Vehículos</a>
      <a href={`${base}/propiedades`} class="text-gray-700 hover:text-primary hover:bg-gray-50 px-3 py-3 rounded-xl text-sm font-medium transition">Propiedades</a>
      <a href={`${base}/otros`}       class="text-gray-700 hover:text-primary hover:bg-gray-50 px-3 py-3 rounded-xl text-sm font-medium transition">Otros</a>
      <a href={`${base}/nosotros`}    class="text-gray-700 hover:text-primary hover:bg-gray-50 px-3 py-3 rounded-xl text-sm font-medium transition">Nosotros</a>
      <a href={`${base}/contacto`}    class="text-gray-700 hover:text-primary hover:bg-gray-50 px-3 py-3 rounded-xl text-sm font-medium transition">Contacto</a>
    </div>
  </header>

  <script is:inline>
    const btn  = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    const lines = btn.querySelectorAll('.ham-line');
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden') === false;
      if (open) {
        lines[0].style.transform = 'translateY(8px) rotate(45deg)';
        lines[1].style.opacity   = '0';
        lines[2].style.transform = 'translateY(-8px) rotate(-45deg)';
      } else {
        lines[0].style.transform = '';
        lines[1].style.opacity   = '';
        lines[2].style.transform = '';
      }
    });
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      menu.classList.add('hidden');
      lines[0].style.transform = '';
      lines[1].style.opacity   = '';
      lines[2].style.transform = '';
    }));
  </script>

  <!-- CONTENIDO -->
  <slot />

  <!-- FOOTER -->
  <footer class="bg-[#0d1f3c] text-white mt-20" style="border-top: 4px solid #F05A1A;">
    <div class="max-w-7xl mx-auto px-5 pt-14 pb-10">
      <div class="flex flex-col md:flex-row items-start justify-between gap-8">

        <div class="max-w-xs">
          <img src={`${base}/logo-bipro-blanco.svg`} alt="Remates BiPro" class="h-20 w-auto mb-3" />
          <p class="text-white/50 text-sm leading-relaxed mb-3">Alternativa moderna, transparente y profesional en remates y gestión de bienes en Chile.</p>
          <p class="text-accent font-semibold text-sm italic">"Transformando oportunidades en nuevos comienzos."</p>
        </div>

        <div>
          <p class="text-white/80 text-sm uppercase tracking-widest font-semibold mb-5">Categorías</p>
          <div class="flex flex-col gap-2 text-sm">
            <a href={`${base}/vehiculos`}   class="text-white/60 hover:text-accent transition">Vehículos</a>
            <a href={`${base}/propiedades`} class="text-white/60 hover:text-accent transition">Propiedades</a>
            <a href={`${base}/otros`}       class="text-white/60 hover:text-accent transition">Otros artículos</a>
          </div>
        </div>

        <div>
          <p class="text-white/80 text-sm uppercase tracking-widest font-semibold mb-5">Nuestro compromiso</p>
          <div class="flex flex-col gap-1.5 text-sm text-white/60">
            <span>✔ Transparencia en cada proceso</span>
            <span>✔ Atención personalizada</span>
            <span>✔ Procesos ágiles y eficientes</span>
            <span>✔ Innovación y tecnología</span>
            <span>✔ Respaldo profesional</span>
          </div>
        </div>

        <div id="contacto">
          <p class="text-white/80 text-sm uppercase tracking-widest font-semibold mb-5">Contacto</p>
          <div class="flex flex-col gap-2 text-sm text-white/60">
            <a href="mailto:contacto@rematesbipro.cl" class="hover:text-accent transition flex items-center gap-1.5">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.8"/></svg>
              contacto@rematesbipro.cl
            </a>
            <a href="tel:+56975884719" class="hover:text-accent transition flex items-center gap-1.5">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C9.61 21 3 14.39 3 6a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.46.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" stroke="currentColor" stroke-width="1.8"/></svg>
              +56 9 7588 4719
            </a>
            <a href="tel:+56950119127" class="hover:text-accent transition flex items-center gap-1.5">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C9.61 21 3 14.39 3 6a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.46.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" stroke="currentColor" stroke-width="1.8"/></svg>
              +56 9 5011 9127
            </a>
            <a href="https://www.instagram.com/rematesbipro/" target="_blank" rel="noopener" class="hover:text-accent transition flex items-center gap-1.5">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><path d="M17.5 6.5h.01"/></svg>
              @rematesbipro
            </a>
            <span class="text-white/40 text-xs mt-1">Chile — Cobertura nacional</span>
          </div>
        </div>

      </div>
      <div class="border-t border-white/10 mt-8 pt-6 flex flex-col md:flex-row items-center justify-between gap-2 text-white/30 text-xs">
        <p>© 2025 BIPRO Remates · Gestión de Activos Chile</p>
        <p>Transparencia · Confianza · Profesionalismo</p>
        <p>Diseño por <a href="https://diseñopaginas.cl" target="_blank" rel="noopener" class="hover:text-white/60 transition underline underline-offset-2">diseñopaginas.cl</a></p>
      </div>
    </div>
  </footer>

</body>
</html>
