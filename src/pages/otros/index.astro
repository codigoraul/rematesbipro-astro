---
import Layout from '../../layouts/Layout.astro';
import { getOtros, getFeaturedImage, getField, formatPrecio, formatFecha } from '../../lib/wordpress.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const otros = await getOtros();
---

<Layout title="Otros Remates">

  <!-- HERO -->
  <section class="bg-primary text-white py-10">
    <div class="max-w-7xl mx-auto px-5">
      <div class="flex items-center gap-3 mb-1">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z" stroke="white" stroke-width="1.8" stroke-linejoin="round"/>
          <circle cx="7" cy="7" r="1.5" fill="white"/>
        </svg>
        <h1 class="text-2xl font-bold tracking-tight">Otros Remates</h1>
      </div>
      <p class="text-blue-200 text-sm">{otros.length} artículo{otros.length !== 1 ? 's' : ''} disponible{otros.length !== 1 ? 's' : ''}</p>
    </div>
  </section>

  <!-- LISTADO -->
  <main class="max-w-7xl mx-auto px-5 py-10">
    {otros.length === 0 ? (
      <div class="text-center py-20 text-gray-400">
        <svg class="mx-auto mb-4 opacity-30" width="64" height="64" viewBox="0 0 24 24" fill="none">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
        <p class="text-lg font-medium text-gray-500">No hay artículos disponibles</p>
        <p class="text-sm mt-1">Vuelve pronto para ver nuevos remates</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {otros.map((o) => {
          const img       = getFeaturedImage(o);
          const categoria = getField(o, 'categoria_item');
          const descripcion = getField(o, 'descripcion');
          const precio    = getField(o, 'precio_base');
          const fecha     = getField(o, 'fecha_remate');
          return (
            <a href={`${base}/otros/${o.slug}`} class="remate-card bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:border-primary/30 block">
              <div class="relative overflow-hidden" style="height:200px">
                {img
                  ? <img src={img} alt={o.title?.rendered || 'Artículo'} class="w-full h-full object-cover" loading="lazy" />
                  : <div class="w-full h-full bg-gray-100 flex items-center justify-center text-gray-300">
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                      </svg>
                    </div>
                }
                {fecha && (
                  <span class="absolute top-3 right-3 bg-accent text-white text-xs font-semibold px-2.5 py-1 rounded-full">
                    {formatFecha(fecha)}
                  </span>
                )}
                {categoria && (
                  <span class="absolute top-3 left-3 bg-white/90 text-gray-700 text-xs font-medium px-2 py-0.5 rounded-full border border-gray-200">
                    {categoria}
                  </span>
                )}
              </div>
              <div class="p-4">
                <h2 class="font-bold text-gray-900 text-base leading-tight truncate">
                  {o.title?.rendered}
                </h2>
                {descripcion && (
                  <p class="text-xs text-gray-500 mt-1 line-clamp-2">{descripcion}</p>
                )}
                <p class="text-accent font-extrabold text-xl mt-3">{formatPrecio(precio)}</p>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </main>

</Layout>
