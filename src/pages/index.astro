---
import Layout from '../layouts/Layout.astro';
import { getVehiculos, getPropiedades, getOtros, getFeaturedImage, getField, formatPrecio, formatFecha, decodeHtml } from '../lib/wordpress.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const vehiculos   = await getVehiculos();
const propiedades = await getPropiedades();
const otros       = await getOtros();
---

<Layout title="Inicio">

  <!-- HERO SLIDER -->
  <section class="relative overflow-hidden" style="height:630px;">
    <div class="slide active" id="slide-0">
      <div class="slide-bg" style={`background-image:url('${base}/images/slider-1.webp');`}></div>
      <div class="relative h-full max-w-7xl mx-auto px-8 flex flex-col justify-center">
        <span class="inline-flex items-center bg-white/15 backdrop-blur border border-white/25 text-white text-xs font-semibold px-3 py-1.5 rounded-full w-fit mb-3 uppercase tracking-widest">Remate activo</span>
        <div class="bg-[#011f52]/35 backdrop-blur-sm rounded-2xl px-8 py-5 w-fit mb-4">
          <h1 class="text-white font-bold text-4xl md:text-5xl leading-tight mb-2 drop-shadow-lg">Remate <span class="text-orange-500">Vehículos</span></h1>
          <p class="text-white/80 text-base max-w-md">Transformando oportunidades en nuevos comienzos.</p>
        </div>
        <div class="flex gap-3">
          <a href={`${base}/vehiculos`} class="bg-[#012A6C] hover:bg-[#011f52] text-white font-bold px-6 py-3 rounded-xl transition shadow-lg">Ver vehículos →</a>
          <a href="#contacto"  class="bg-white/15 hover:bg-white/25 backdrop-blur text-white font-semibold px-6 py-3 rounded-xl transition border border-white/30">Cómo participar</a>
        </div>
      </div>
    </div>

    <div class="slide" id="slide-1">
      <div class="slide-bg" style={`background-image:url('${base}/images/slider-2.webp');`}></div>
      <div class="relative h-full max-w-7xl mx-auto px-8 flex flex-col justify-center">
        <span class="inline-flex items-center bg-white/15 backdrop-blur border border-white/25 text-white text-xs font-semibold px-3 py-1.5 rounded-full w-fit mb-3 uppercase tracking-widest">Remate activo</span>
        <div class="bg-[#011f52]/35 backdrop-blur-sm rounded-2xl px-8 py-5 w-fit mb-4">
          <h1 class="text-white font-bold text-4xl md:text-5xl leading-tight mb-2 drop-shadow-lg">Remate <span class="text-orange-500">Propiedades</span></h1>
          <p class="text-white/80 text-base max-w-md">Alternativa moderna, transparente y profesional en gestión de bienes.</p>
        </div>
        <div class="flex gap-3">
          <a href={`${base}/propiedades`} class="bg-[#012A6C] hover:bg-[#011f52] text-white font-bold px-6 py-3 rounded-xl transition shadow-lg">Ver propiedades →</a>
          <a href="#contacto"    class="bg-white/15 hover:bg-white/25 backdrop-blur text-white font-semibold px-6 py-3 rounded-xl transition border border-white/30">Cómo participar</a>
        </div>
      </div>
    </div>

    <div class="slide" id="slide-2">
      <div class="slide-bg" style={`background-image:url('${base}/images/slider-3.webp');`}></div>
      <div class="relative h-full max-w-7xl mx-auto px-8 flex flex-col justify-center">
        <span class="inline-flex items-center bg-white/15 backdrop-blur border border-white/25 text-white text-xs font-semibold px-3 py-1.5 rounded-full w-fit mb-3 uppercase tracking-widest">Remate activo</span>
        <div class="bg-[#011f52]/35 backdrop-blur-sm rounded-2xl px-8 py-5 w-fit mb-4">
          <h1 class="text-white font-bold text-4xl md:text-5xl leading-tight mb-2 drop-shadow-lg">Remate <span class="text-orange-500">Maquinaria</span></h1>
          <p class="text-white/80 text-base max-w-md">Equipos y maquinaria pesada disponibles para remate.</p>
        </div>
        <div class="flex gap-3">
          <a href={`${base}/otros`} class="bg-[#012A6C] hover:bg-[#011f52] text-white font-bold px-6 py-3 rounded-xl transition shadow-lg">Ver maquinaria →</a>
          <a href="#contacto" class="bg-white/15 hover:bg-white/25 backdrop-blur text-white font-semibold px-6 py-3 rounded-xl transition border border-white/30">Cómo participar</a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-7 left-1/2 -translate-x-1/2 flex gap-2.5 z-10">
      <button onclick="goSlide(0)" class="dot active w-3 h-3 rounded-full bg-white/50 transition-all" id="dot-0"></button>
      <button onclick="goSlide(1)" class="dot w-3 h-3 rounded-full bg-white/50 transition-all" id="dot-1"></button>
      <button onclick="goSlide(2)" class="dot w-3 h-3 rounded-full bg-white/50 transition-all" id="dot-2"></button>
    </div>
    <button onclick="prevSlide()" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 bg-white/15 hover:bg-white/30 text-white w-11 h-11 rounded-full flex items-center justify-center border border-white/20 text-xl">‹</button>
    <button onclick="nextSlide()" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 bg-white/15 hover:bg-white/30 text-white w-11 h-11 rounded-full flex items-center justify-center border border-white/20 text-xl">›</button>
  </section>

  <!-- STATS BAR -->
  <div class="bg-[#012A6C] text-white">
    <div class="max-w-7xl mx-auto px-5 py-4 flex flex-wrap justify-around gap-4 text-center">
      <div><div class="text-2xl font-bold">{vehiculos.length}</div><div class="text-xs text-blue-200 uppercase tracking-wider">Vehículos</div></div>
      <div class="w-px bg-white/20 hidden md:block"></div>
      <div><div class="text-2xl font-bold">{propiedades.length}</div><div class="text-xs text-blue-200 uppercase tracking-wider">Propiedades</div></div>
      <div class="w-px bg-white/20 hidden md:block"></div>
      <div><div class="text-2xl font-bold">{otros.length}</div><div class="text-xs text-blue-200 uppercase tracking-wider">Otros ítems</div></div>
      <div class="w-px bg-white/20 hidden md:block"></div>
      <div><div class="text-2xl font-bold">Nacional</div><div class="text-xs text-blue-200 uppercase tracking-wider">Cobertura Chile</div></div>
    </div>
  </div>

  <main class="max-w-7xl mx-auto px-5 py-12">

    <!-- VEHÍCULOS -->
    <div class="mb-14">
      <div class="flex items-center gap-3 mb-6">
        <svg class="w-6 h-6 text-[#012A6C]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 17h8M4 11l2-5h12l2 5M4 11h16v5a1 1 0 01-1 1H5a1 1 0 01-1-1v-5z"/><circle cx="7.5" cy="17.5" r="1.5" fill="currentColor" stroke="none"/><circle cx="16.5" cy="17.5" r="1.5" fill="currentColor" stroke="none"/></svg>
        <h2 class="text-2xl font-extrabold text-[#011f52]">Vehículos</h2>
        <div class="flex-1 h-0.5 bg-gradient-to-r from-[#012A6C] to-transparent rounded"></div>
        <a href={`${base}/vehiculos`} class="bg-[#012A6C] text-white text-xs font-bold px-3 py-1 rounded-full">{vehiculos.length} disponibles</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {vehiculos.slice(0, 4).map((v) => {
          const img    = getFeaturedImage(v);
          const precio = getField(v, 'precio_base');
          const anio   = getField(v, 'anio');
          const km     = getField(v, 'kilometraje');
          const estado = getField(v, 'estado');
          const fecha  = getField(v, 'fecha_remate');
          return (
            <a href={`${base}/vehiculos/${v.slug}`} class="remate-card bg-white rounded-2xl overflow-hidden shadow-md block">
              <div class="relative">
                {img ? <img src={img} class="w-full h-44 object-cover" alt={decodeHtml(v.title.rendered)} /> : <div class="w-full h-44 bg-gray-200 flex items-center justify-center text-gray-400 text-sm">Sin imagen</div>}
                <span class="absolute top-2.5 left-2.5 bg-[#012A6C] text-white text-[10px] font-bold px-2 py-0.5 rounded uppercase">Vehículo</span>
                {fecha && <span class="absolute top-2.5 right-2.5 bg-orange-500 text-white text-[10px] font-bold px-2 py-0.5 rounded">{formatFecha(fecha)}</span>}
              </div>
              <div class="p-4">
                <h3 class="font-bold text-gray-900 mb-2 line-clamp-1">{decodeHtml(v.title.rendered)}</h3>
                <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs text-[#6F7983] mb-3">
                  {anio && <span class="inline-flex items-center gap-1"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>{anio}</span>}
                  {km   && <span class="inline-flex items-center gap-1"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>{Number(km).toLocaleString('es-CL')} km</span>}
                  {estado && <span class="inline-flex items-center gap-1 text-emerald-600"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>{estado.replace(/_/g, ' ')}</span>}
                </div>
                <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                  <div>
                    <p class="text-[10px] text-[#6F7983] uppercase tracking-wide">Base remate</p>
                    <p class="text-[#012A6C] font-extrabold text-lg">{formatPrecio(precio)}</p>
                  </div>
                  <span class="bg-[#012A6C] text-white text-xs font-semibold px-3 py-1.5 rounded-lg">Ver más</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
      {vehiculos.length > 4 && <div class="text-center mt-6"><a href={`${base}/vehiculos`} class="inline-block bg-[#012A6C] hover:bg-[#011f52] text-white font-semibold px-6 py-2.5 rounded-xl transition">Ver todos los vehículos →</a></div>}
    </div>

    <!-- BANNER GARANTÍA -->
    <div class="mb-14 rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
      <div class="bg-primary text-white px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <p class="font-extrabold text-lg">Garantía para participar en el remate</p>
          <p class="text-white/70 text-sm">Debes constituir la garantía en la cuenta corriente indicada abajo antes del remate.</p>
        </div>
        <a href={`${base}/docs/bases-remate-vehiculos-bipro.pdf`} target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 bg-accent hover:bg-orange-600 text-white font-bold px-5 py-2.5 rounded-xl transition text-sm whitespace-nowrap">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 3v12m0 0l-4-4m4 4l4-4M4 21h16" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Descargar bases del remate
        </a>
      </div>
      <div class="bg-orange-50 px-6 py-4 grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
        <div class="text-gray-700 leading-relaxed">
          <p><span class="font-bold">BIPRO SpA</span> · RUT 78.416.392-K</p>
          <p>Banco BCI · Cuenta Corriente N° 77175996</p>
          <p>garantia@rematesbipro.cl</p>
          <p class="mt-2">Para más información: <a href="tel:+56948041797" class="font-semibold hover:text-primary transition">+56 9 4804 1797</a> · <a href="tel:+56950119127" class="font-semibold hover:text-primary transition">+56 9 5011 9127</a> · <a href="tel:+56975884719" class="font-semibold hover:text-primary transition">+56 9 7588 4719</a></p>
        </div>
        <div class="sm:text-right">
          <p class="text-gray-400 text-xs uppercase tracking-wide font-semibold">Valor de garantía</p>
          <p class="text-accent font-extrabold text-2xl">$300.000</p>
        </div>
      </div>
    </div>

    <!-- PROPIEDADES -->
    <div class="mb-14">
      <div class="flex items-center gap-3 mb-6">
        <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <h2 class="text-2xl font-extrabold text-[#011f52]">Propiedades</h2>
        <div class="flex-1 h-0.5 bg-gradient-to-r from-[#012A6C] to-transparent rounded"></div>
        <a href={`${base}/propiedades`} class="bg-emerald-600 text-white text-xs font-bold px-3 py-1 rounded-full">{propiedades.length} disponibles</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {propiedades.slice(0, 3).map((p) => {
          const img    = getFeaturedImage(p);
          const precio = getField(p, 'precio_base');
          const tipo   = getField(p, 'tipo_propiedad');
          const sup    = getField(p, 'superficie_m2');
          const comuna = getField(p, 'comuna');
          const fecha  = getField(p, 'fecha_remate');
          return (
            <a href={`${base}/propiedades/${p.slug}`} class="remate-card bg-white rounded-2xl overflow-hidden shadow-md block">
              <div class="relative">
                {img ? <img src={img} class="w-full h-48 object-cover" alt={decodeHtml(p.title.rendered)} /> : <div class="w-full h-48 bg-gray-200 flex items-center justify-center text-gray-400 text-sm">Sin imagen</div>}
                <span class="absolute top-2.5 left-2.5 bg-emerald-600 text-white text-[10px] font-bold px-2 py-0.5 rounded uppercase">{tipo || 'Propiedad'}</span>
                {fecha && <span class="absolute top-2.5 right-2.5 bg-orange-500 text-white text-[10px] font-bold px-2 py-0.5 rounded">{formatFecha(fecha)}</span>}
              </div>
              <div class="p-4">
                <h3 class="font-bold text-gray-900 mb-2 line-clamp-1">{decodeHtml(p.title.rendered)}</h3>
                <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs text-[#6F7983] mb-3">
                  {sup    && <span class="inline-flex items-center gap-1"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5v-4m0 4h-4m4 0l-5-5"/></svg>{sup} m²</span>}
                  {comuna && <span class="inline-flex items-center gap-1"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>{comuna}</span>}
                </div>
                <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                  <div>
                    <p class="text-[10px] text-[#6F7983] uppercase tracking-wide">Base remate</p>
                    <p class="text-[#012A6C] font-extrabold text-lg">{formatPrecio(precio)}</p>
                  </div>
                  <span class="bg-[#012A6C] text-white text-xs font-semibold px-3 py-1.5 rounded-lg">Ver más</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
      {propiedades.length > 3 && <div class="text-center mt-6"><a href={`${base}/propiedades`} class="inline-block bg-[#012A6C] hover:bg-[#011f52] text-white font-semibold px-6 py-2.5 rounded-xl transition">Ver todas las propiedades →</a></div>}
    </div>

    <!-- OTROS -->
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-6">
        <svg class="w-6 h-6 text-[#6F7983]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        <h2 class="text-2xl font-extrabold text-[#011f52]">Otros</h2>
        <div class="flex-1 h-0.5 bg-gradient-to-r from-[#012A6C] to-transparent rounded"></div>
        <a href={`${base}/otros`} class="bg-[#6F7983] text-white text-xs font-bold px-3 py-1 rounded-full">{otros.length} disponibles</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {otros.slice(0, 3).map((o) => {
          const img    = getFeaturedImage(o);
          const precio = getField(o, 'precio_base');
          const cat    = getField(o, 'categoria');
          const estado = getField(o, 'estado');
          const fecha  = getField(o, 'fecha_remate');
          return (
            <a href={`${base}/otros/${o.slug}`} class="remate-card bg-white rounded-2xl overflow-hidden shadow-md block">
              <div class="relative">
                {img ? <img src={img} class="w-full h-44 object-cover" alt={decodeHtml(o.title.rendered)} /> : <div class="w-full h-44 bg-gray-200 flex items-center justify-center text-gray-400 text-sm">Sin imagen</div>}
                <span class="absolute top-2.5 left-2.5 bg-[#6F7983] text-white text-[10px] font-bold px-2 py-0.5 rounded uppercase">{cat || 'Otros'}</span>
                {fecha && <span class="absolute top-2.5 right-2.5 bg-orange-500 text-white text-[10px] font-bold px-2 py-0.5 rounded">{formatFecha(fecha)}</span>}
              </div>
              <div class="p-4">
                <h3 class="font-bold text-gray-900 mb-2 line-clamp-1">{decodeHtml(o.title.rendered)}</h3>
                <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs text-[#6F7983] mb-3">
                  {estado && <span class="inline-flex items-center gap-1 text-emerald-600"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>{estado.replace(/_/g, ' ')}</span>}
                </div>
                <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                  <div>
                    <p class="text-[10px] text-[#6F7983] uppercase tracking-wide">Base remate</p>
                    <p class="text-[#012A6C] font-extrabold text-lg">{formatPrecio(precio)}</p>
                  </div>
                  <span class="bg-[#012A6C] text-white text-xs font-semibold px-3 py-1.5 rounded-lg">Ver más</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>

  </main>

  <!-- QUIÉNES SOMOS -->
  <section class="bg-white py-16 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-5 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="inline-block text-xs font-bold uppercase tracking-widest text-[#012A6C] bg-blue-50 px-3 py-1 rounded-full mb-4">Nuestra Historia</span>
        <h2 class="text-4xl md:text-5xl font-bold text-[#011f52] leading-tight mb-5">
          Transformando oportunidades<br class="hidden md:block"/> en nuevos comienzos
        </h2>
        <p class="text-gray-600 text-base leading-relaxed mb-4">
          BIPRO Remates nace con la convicción de hacer las cosas de manera diferente. Creamos esta empresa con el objetivo de entregar un servicio de remates moderno, transparente y cercano, enfocado en generar confianza tanto en personas como en empresas que necesitan vender o adquirir bienes de forma segura y eficiente.
        </p>
        <p class="text-gray-600 text-base leading-relaxed mb-4">
          Entendemos que detrás de cada remate existe una necesidad importante: cerrar un ciclo, recuperar valor, generar nuevas oportunidades o dar un nuevo destino a distintos bienes. Por eso trabajamos con responsabilidad, compromiso y seriedad profesional en cada operación.
        </p>
        <p class="text-[#012A6C] font-bold text-lg italic">"Transformando oportunidades en nuevos comienzos."</p>
      </div>
      <div class="grid grid-cols-1 gap-5">
        <div class="bg-blue-50 rounded-2xl p-6 flex gap-4 items-start">
          <div class="w-9 h-9 flex-shrink-0 text-[#012A6C]"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/></svg></div>
          <div>
            <h3 class="font-bold text-[#011f52] mb-1">Nuestra Misión</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Entregar soluciones eficientes y confiables en remates y gestión de activos, ofreciendo un servicio cercano, transparente y respaldado por herramientas tecnológicas modernas.</p>
          </div>
        </div>
        <div class="bg-blue-50 rounded-2xl p-6 flex gap-4 items-start">
          <div class="w-9 h-9 flex-shrink-0 text-[#012A6C]"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
          <div>
