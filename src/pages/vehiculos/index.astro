---
import Layout from '../../layouts/Layout.astro';
import { getVehiculos, getFeaturedImage, getField, formatPrecio, formatFecha } from '../../lib/wordpress.js';

const base = import.meta.env.BASE_URL;
const vehiculos = await getVehiculos();
---

<Layout title="Vehículos en Remate">

  <!-- HERO -->
  <section class="relative text-white py-16 overflow-hidden" style="min-height:160px">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image:url('https://images.unsplash.com/photo-1580273916550-e323be2ae537?w=1600&q=60&fm=webp')"></div>
    <div class="absolute inset-0" style="background:linear-gradient(90deg,rgba(13,31,60,0.88) 0%,rgba(13,31,60,0.65) 100%)"></div>
    <div class="relative max-w-7xl mx-auto px-5">
      <div class="flex items-center gap-3 mb-1">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 17h18M3 17a2 2 0 01-2-2v-1l2-6h14l2 6v1a2 2 0 01-2 2M3 17l1 3h2l1-3M21 17l-1 3h-2l-1-3M8 10h8" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="7.5" cy="17" r="1.5" fill="white"/>
          <circle cx="16.5" cy="17" r="1.5" fill="white"/>
        </svg>
        <h1 class="text-2xl font-bold tracking-tight">Vehículos en Remate</h1>
      </div>
      <p class="text-blue-200 text-sm">{vehiculos.length} vehículo{vehiculos.length !== 1 ? 's' : ''} disponible{vehiculos.length !== 1 ? 's' : ''}</p>
    </div>
  </section>

  <!-- LISTADO -->
  <main class="max-w-7xl mx-auto px-5 py-10">
    {vehiculos.length === 0 ? (
      <div class="text-center py-20 text-gray-400">
        <svg class="mx-auto mb-4 opacity-30" width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 17h18M3 17a2 2 0 01-2-2v-1l2-6h14l2 6v1a2 2 0 01-2 2M3 17l1 3h2l1-3M21 17l-1 3h-2l-1-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <p class="text-lg font-medium text-gray-500">No hay vehículos disponibles</p>
        <p class="text-sm mt-1">Vuelve pronto para ver nuevos remates</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {vehiculos.map((v) => {
          const img     = getFeaturedImage(v);
          const marca   = getField(v, 'marca');
          const modelo  = getField(v, 'modelo');
          const anio    = getField(v, 'anio');
          const km      = getField(v, 'kilometraje');
          const precio  = getField(v, 'precio_base');
          const fecha   = getField(v, 'fecha_remate');
          const estado  = getField(v, 'estado_vehiculo');
          return (
            <a href={`${base}/vehiculos/${v.slug}`} class="remate-card bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:border-primary/30 block">
              <div class="relative overflow-hidden" style="height:200px">
                {img
                  ? <img src={img} alt={v.title?.rendered || 'Vehículo'} class="w-full h-full object-cover" loading="lazy" />
                  : <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" class="text-gray-300">
                        <path d="M3 17h18M3 17a2 2 0 01-2-2v-1l2-6h14l2 6v1a2 2 0 01-2 2M3 17l1 3h2l1-3M21 17l-1 3h-2l-1-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </div>
                }
                {fecha && (
                  <span class="absolute top-3 right-3 bg-accent text-white text-xs font-semibold px-2.5 py-1 rounded-full">
                    {formatFecha(fecha)}
                  </span>
                )}
                {estado && (
                  <span class="absolute top-3 left-3 bg-white/90 text-gray-700 text-xs font-medium px-2 py-0.5 rounded-full border border-gray-200">
                    {estado}
                  </span>
                )}
              </div>
              <div class="p-4">
                <h2 class="font-bold text-gray-900 text-base leading-tight truncate">
                  {marca && modelo ? `${marca} ${modelo}` : v.title?.rendered}
                </h2>
                <div class="flex flex-wrap gap-x-3 gap-y-1 mt-2 text-xs text-gray-500">
                  {anio && (
                    <span class="meta-icon">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.8"/>
                        <path d="M3 9h18M8 2v4M16 2v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                      </svg>
                      {anio}
                    </span>
                  )}
                  {km && (
                    <span class="meta-icon">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/>
                        <path d="M12 12l3-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                        <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
                      </svg>
                      {Number(km).toLocaleString('es-CL')} km
                    </span>
                  )}
                </div>
                <p class="text-accent font-extrabold text-xl mt-3">{formatPrecio(precio)}</p>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </main>

  <!-- BANNER GARANTÍA -->
  <section class="bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-5 py-10">
      <div class="rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
        <div class="bg-primary text-white px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <div>
            <p class="font-extrabold text-lg">Garantía para participar en el remate</p>
            <p class="text-white/70 text-sm">Debes constituir la garantía en la cuenta corriente indicada abajo antes del remate.</p>
          </div>
          <a href={`${base}/docs/bases-remate-vehiculos-bipro.pdf`} target="_blank" rel="noopener"
            class="inline-flex items-center gap-2 bg-accent hover:bg-orange-600 text-white font-bold px-5 py-2.5 rounded-xl transition text-sm whitespace-nowrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 3v12m0 0l-4-4m4 4l4-4M4 21h16" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Descargar bases del remate
          </a>
        </div>
        <div class="bg-orange-50 px-6 py-4 grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
          <div class="text-gray-700 leading-relaxed">
            <p><span class="font-bold">BIPRO SpA</span> · RUT 78.416.392-K</p>
            <p>Banco BCI · Cuenta Corriente N° 77175996</p>
            <p>garantia@rematesbipro.cl</p>
            <p class="mt-2">Para más información: <a href="tel:+56948041797" class="font-semibold hover:text-primary transition">+56 9 4804 1797</a> · <a href="tel:+56950119127" class="font-semibold hover:text-primary transition">+56 9 5011 9127</a> · <a href="tel:+56975884719" class="font-semibold hover:text-primary transition">+56 9 7588 4719</a></p>
          </div>
          <div class="sm:text-right">
            <p class="text-gray-400 text-xs uppercase tracking-wide font-semibold">Valor de garantía</p>
            <p class="text-accent font-extrabold text-2xl">$300.000</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
