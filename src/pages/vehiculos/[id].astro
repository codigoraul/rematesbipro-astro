---
import Layout from '../../layouts/Layout.astro';
import { getVehiculos, getVehiculo, getFeaturedImage, getField, formatPrecio, formatFecha, decodeHtml, getYoastSEO } from '../../lib/wordpress.js';

export async function getStaticPaths() {
  const vehiculos = await getVehiculos();
  return vehiculos.map((v) => ({ params: { id: String(v.id) } }));
}

const { id } = Astro.params;
const base = import.meta.env.BASE_URL;
const v = await getVehiculo(id);

const img      = getFeaturedImage(v);
const marca    = getField(v, 'marca');
const modelo   = getField(v, 'modelo');
const anio     = getField(v, 'anio');
const km       = getField(v, 'kilometraje');
const precio   = getField(v, 'precio_base');
const fecha    = getField(v, 'fecha_remate');
const estado   = getField(v, 'estado_vehiculo');
const galeria  = getField(v, 'galeria');  // array of image objects or URLs

const titulo   = marca && modelo ? `${marca} ${modelo}` : decodeHtml(v.title?.rendered);
const seo      = getYoastSEO(v);

// Recopilar imágenes: featured + ACF galería + adjuntos WP
const imgs: string[] = [];
if (img) imgs.push(img);
if (Array.isArray(galeria)) {
  galeria.forEach((g: any) => {
    const url = typeof g === 'string' ? g : (g?.url || g?.source_url || null);
    if (url && !imgs.includes(url)) imgs.push(url);
  });
}
if (Array.isArray((v as any)._attachments)) {
  (v as any)._attachments.forEach((url: string) => {
    if (url && !imgs.includes(url)) imgs.push(url);
  });
}
---

<Layout 
  title={seo?.title || titulo}
  description={seo?.description}
  ogImage={seo?.ogImage || img}
  canonical={seo?.canonical}
>

  <!-- BREADCRUMB -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-5 py-3 flex items-center gap-2 text-sm text-gray-500">
      <a href={base} class="hover:text-primary transition">Inicio</a>
      <span>/</span>
      <a href={`${base}/vehiculos`} class="hover:text-primary transition">Vehículos</a>
      <span>/</span>
      <span class="text-gray-800 font-medium truncate max-w-xs">{titulo}</span>
    </div>
  </div>

  <main class="max-w-7xl mx-auto px-5 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

      <!-- GALERÍA -->
      <div>
        {imgs.length > 0 ? (
          <div>
            <div class="relative rounded-2xl overflow-hidden bg-gray-100 group" style="height:420px">
              <img id="main-img" src={imgs[0]} alt={titulo}
                class="w-full h-full object-cover cursor-zoom-in transition-transform duration-300 group-hover:scale-[1.02]"
                onclick="openLightbox(0)"
              />
              {imgs.length > 1 && (
                <>
                  <button onclick="prevSlide()" class="absolute left-3 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/70 text-white rounded-full w-9 h-9 flex items-center justify-center transition z-10">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="white" stroke-width="2.2" stroke-linecap="round"/></svg>
                  </button>
                  <button onclick="nextSlide()" class="absolute right-3 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/70 text-white rounded-full w-9 h-9 flex items-center justify-center transition z-10">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="white" stroke-width="2.2" stroke-linecap="round"/></svg>
                  </button>
                  <div class="absolute bottom-3 left-1/2 -translate-x-1/2 bg-black/40 text-white text-xs px-2.5 py-1 rounded-full font-medium" id="slide-counter">
                    1 / {imgs.length}
                  </div>
                  <button onclick="openLightbox(currentIdx)" class="absolute top-3 right-3 bg-black/40 hover:bg-black/70 text-white rounded-lg w-8 h-8 flex items-center justify-center transition">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
                  </button>
                </>
              )}
            </div>
            {imgs.length > 1 && (
              <div class="flex gap-2 mt-3 overflow-x-auto pb-1 snap-x">
                {imgs.map((src, i) => (
                  <button
                    class={`thumb-btn flex-shrink-0 rounded-xl overflow-hidden border-2 transition snap-start ${i === 0 ? 'border-primary ring-2 ring-primary/20' : 'border-transparent hover:border-gray-300'}`}
                    style="width:120px;height:80px"
                    data-idx={i}
                    onclick={`goToSlide(${i})`}
                  >
                    <img src={src} alt="" class="w-full h-full object-cover" loading="lazy" />
                  </button>
                ))}
              </div>
            )}
          </div>
        ) : (
          <div class="rounded-2xl bg-gray-100 flex items-center justify-center" style="height:420px">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" class="text-gray-300">
              <path d="M3 17h18M3 17a2 2 0 01-2-2v-1l2-6h14l2 6v1a2 2 0 01-2 2M3 17l1 3h2l1-3M21 17l-1 3h-2l-1-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </div>
        )}
      </div>

      <!-- LIGHTBOX -->
      <div id="lightbox" class="fixed inset-0 bg-black/95 z-50 hidden items-center justify-center" onclick="closeLightboxOutside(event)">
        <button onclick="closeLightbox()" class="absolute top-4 right-4 text-white bg-white/10 hover:bg-white/20 rounded-full w-10 h-10 flex items-center justify-center transition z-10">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="white" stroke-width="2.2" stroke-linecap="round"/></svg>
        </button>
        <button onclick="lbPrev()" class="absolute left-4 top-1/2 -translate-y-1/2 text-white bg-white/10 hover:bg-white/20 rounded-full w-11 h-11 flex items-center justify-center transition">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="white" stroke-width="2.2" stroke-linecap="round"/></svg>
        </button>
        <button onclick="lbNext()" class="absolute right-4 top-1/2 -translate-y-1/2 text-white bg-white/10 hover:bg-white/20 rounded-full w-11 h-11 flex items-center justify-center transition">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="white" stroke-width="2.2" stroke-linecap="round"/></svg>
        </button>
        <img id="lb-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg select-none" />
        <div id="lb-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/60 text-sm font-medium"></div>
      </div>

      <!-- DETALLES -->
      <div class="flex flex-col">
        <h1 class="text-3xl font-extrabold text-gray-900 leading-tight">{titulo}</h1>

        {estado && (
          <span class="mt-2 inline-flex w-fit items-center bg-blue-50 text-primary text-sm font-semibold px-3 py-1 rounded-full border border-primary/20">
            {estado}
          </span>
        )}

        <p class="text-accent font-extrabold mt-4" style="font-size:32px">{formatPrecio(precio)}</p>
        <p class="text-gray-400 text-sm mt-0.5">Precio base de remate</p>

        <!-- FICHA TÉCNICA -->
        <div class="mt-6 bg-gray-50 rounded-2xl p-5 grid grid-cols-2 gap-4">
          {marca && (
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold">Marca</p>
              <p class="text-gray-800 font-semibold mt-0.5">{marca}</p>
            </div>
          )}
          {modelo && (
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold">Modelo</p>
              <p class="text-gray-800 font-semibold mt-0.5">{modelo}</p>
            </div>
          )}
          {anio && (
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold">Año</p>
              <p class="text-gray-800 font-semibold mt-0.5">{anio}</p>
            </div>
          )}
          {km && (
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold">Kilometraje</p>
              <p class="text-gray-800 font-semibold mt-0.5">{Number(km).toLocaleString('es-CL')} km</p>
            </div>
          )}
          {fecha && (
            <div class="col-span-2">
              <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold">Fecha de remate</p>
              <p class="text-accent font-bold mt-0.5 text-lg">{formatFecha(fecha)}</p>
              <div class="flex flex-wrap gap-2 mt-3"
                id="cal-btns"
                data-fecha={String(fecha).replace(/-/g,'')}
                data-titulo={titulo}
                data-precio={precio ? formatPrecio(precio) : ''}
              >
                <button onclick="calGoogle()" class="cal-btn inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-lg border border-gray-200 bg-white hover:bg-gray-50 text-gray-700 transition">
                  <svg width="13" height="13" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                  Google Calendar
                </button>
                <button onclick="calIcal()" class="cal-btn inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-lg border border-gray-200 bg-white hover:bg-gray-50 text-gray-700 transition">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="18" rx="2" fill="#1a1a1a"/><path d="M2 9h20" stroke="white" stroke-width="1.5"/><path d="M7 2v4M17 2v4" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round"/><rect x="7" y="2" width="2" height="4" rx="1" fill="#555"/><rect x="15" y="2" width="2" height="4" rx="1" fill="#555"/></svg>
                  Apple / iCal
                </button>
              </div>
            </div>
          )}
        </div>

        <!-- DESCRIPCIÓN -->
        {v.content?.rendered && (
          <div class="mt-5 prose prose-sm max-w-none text-gray-600" set:html={v.content.rendered} />
        )}

        <!-- CTA -->
        <div id="contacto" class="mt-8 bg-primary/5 rounded-2xl p-5 border border-primary/10">
          <p class="font-bold text-gray-800 text-base mb-1">¿Te interesa este vehículo?</p>
          <p class="text-gray-500 text-sm mb-4">Contáctanos para más información o para participar en el remate.</p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a id="wa-btn" href="#" target="_blank"
              class="flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white font-semibold px-5 py-2.5 rounded-xl transition text-sm">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.849L.057 23.617a.75.75 0 00.92.921l5.849-1.47A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.706 9.706 0 01-4.95-1.355l-.355-.211-3.676.923.94-3.591-.232-.368A9.719 9.719 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/></svg>
              Consultar por WhatsApp
            </a>
            <a href={`${base}/contacto`} class="flex items-center justify-center gap-2 bg-primary hover:bg-dark text-white font-semibold px-5 py-2.5 rounded-xl transition text-sm">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="2" stroke="white" stroke-width="1.8"/><path d="M2 7l10 7 10-7" stroke="white" stroke-width="1.8"/></svg>
              Enviar consulta
            </a>
            <a href={`${base}/vehiculos`} class="flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-700 font-semibold px-5 py-2.5 rounded-xl transition text-sm border border-gray-200">
              ← Ver todos
            </a>
          </div>
        </div>
      </div>

    </div>
  </main>

<!-- Datos de imágenes para el JS -->
<div id="gallery-data" data-imgs={JSON.stringify(imgs)} class="hidden"></div>

</Layout>

<script>
  // ── Add to Calendar ──────────────────────────────────────────
  function calData() {
    const el = document.getElementById('cal-btns')!;
    const d  = (el as HTMLElement).dataset;
    const f  = d.fecha!;
    const iso = `${f.slice(0,4)}-${f.slice(4,6)}-${f.slice(6,8)}`;
    return { raw: f, iso, titulo: d.titulo!, precio: d.precio! };
  }
  function calGoogle() {
    const { raw, titulo, precio } = calData();
    window.open(`https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent('Remate: '+titulo)}&dates=${raw}/${raw}&details=${encodeURIComponent('Precio base: '+precio+'\nRematesBiPro — Gestión de Activos')}&location=Chile`, '_blank');
  }
  function calIcal() {
    const { raw, titulo, precio } = calData();
    const uid = raw + '-' + Math.random().toString(36).slice(2,9) + '@rematesbipro.cl';
    const ics = ['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//RematesBiPro//ES','BEGIN:VEVENT',`DTSTART;VALUE=DATE:${raw}`,`DTEND;VALUE=DATE:${raw}`,`SUMMARY:Remate: ${titulo}`,`DESCRIPTION:Precio base: ${precio} - RematesBiPro`,'LOCATION:Chile',`UID:${uid}`,'END:VEVENT','END:VCALENDAR'].join('\r\n');
    const a = document.createElement('a');
    a.href = 'data:text/calendar;charset=utf-8,' + encodeURIComponent(ics);
    a.download = `remate-${raw}.ics`;
    a.click();
  }
  function calOutlook() {
    const { iso, titulo, precio } = calData();
    window.open(`https://outlook.live.com/calendar/0/deeplink/compose?path=/calendar/action/compose&rru=addevent&subject=${encodeURIComponent('Remate: '+titulo)}&startdt=${iso}&enddt=${iso}&body=${encodeURIComponent('Precio base: '+precio+'\nRematesBiPro — Gestión de Activos')}`, '_blank');
  }
  (window as any).calGoogle  = calGoogle;
  (window as any).calIcal    = calIcal;
  (window as any).calOutlook = calOutlook;

  // ── CARRUSEL ──────────────────────────────
  const imgs: string[] = JSON.parse(document.getElementById('gallery-data')?.dataset.imgs || '[]');
  let currentIdx = 0;

  function goToSlide(idx: number) {
    if (!imgs.length) return;
    currentIdx = (idx + imgs.length) % imgs.length;
    const mainImg = document.getElementById('main-img') as HTMLImageElement;
    if (mainImg) mainImg.src = imgs[currentIdx];
    const counter = document.getElementById('slide-counter');
    if (counter) counter.textContent = `${currentIdx + 1} / ${imgs.length}`;
    document.querySelectorAll('.thumb-btn').forEach((b, i) => {
      b.classList.toggle('border-primary', i === currentIdx);
      b.classList.toggle('ring-2', i === currentIdx);
      b.classList.toggle('ring-primary/20', i === currentIdx);
      b.classList.toggle('border-transparent', i !== currentIdx);
    });
    const activeThumb = document.querySelector(`.thumb-btn[data-idx="${currentIdx}"]`);
    activeThumb?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }
  function nextSlide() { goToSlide(currentIdx + 1); }
  function prevSlide() { goToSlide(currentIdx - 1); }

  // ── LIGHTBOX ──────────────────────────────
  function openLightbox(idx: number) {
    currentIdx = idx;
    const lb = document.getElementById('lightbox')!;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    const lbCounter = document.getElementById('lb-counter')!;
    lbImg.src = imgs[currentIdx];
    lbCounter.textContent = `${currentIdx + 1} / ${imgs.length}`;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    const lb = document.getElementById('lightbox')!;
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.body.style.overflow = '';
  }
  function closeLightboxOutside(e: MouseEvent) {
    if ((e.target as HTMLElement).id === 'lightbox') closeLightbox();
  }
  function lbNext() {
    currentIdx = (currentIdx + 1) % imgs.length;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    lbImg.src = imgs[currentIdx];
    document.getElementById('lb-counter')!.textContent = `${currentIdx + 1} / ${imgs.length}`;
    goToSlide(currentIdx);
  }
  function lbPrev() {
    currentIdx = (currentIdx - 1 + imgs.length) % imgs.length;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    lbImg.src = imgs[currentIdx];
    document.getElementById('lb-counter')!.textContent = `${currentIdx + 1} / ${imgs.length}`;
    goToSlide(currentIdx);
  }

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    const lb = document.getElementById('lightbox')!;
    if (!lb.classList.contains('hidden')) {
      if (e.key === 'ArrowRight') lbNext();
      if (e.key === 'ArrowLeft') lbPrev();
      if (e.key === 'Escape') closeLightbox();
    }
  });

  (window as any).goToSlide = goToSlide;
  (window as any).nextSlide = nextSlide;
  (window as any).prevSlide = prevSlide;
  (window as any).openLightbox = openLightbox;
  (window as any).closeLightbox = closeLightbox;
  (window as any).closeLightboxOutside = closeLightboxOutside;
  (window as any).lbNext = lbNext;
  (window as any).lbPrev = lbPrev;
  (window as any).currentIdx = currentIdx;

  // WhatsApp
  const waBtn = document.getElementById('wa-btn') as HTMLAnchorElement;
  if (waBtn) {
    const titulo = document.querySelector('h1')?.textContent?.trim() || 'este vehículo';
    const url = window.location.href;
    const msg = encodeURIComponent(`Hola, me interesa este vehículo:\n*${titulo}*\n${url}`);
    waBtn.href = `https://wa.me/56975884719?text=${msg}`;
  }
</script>
