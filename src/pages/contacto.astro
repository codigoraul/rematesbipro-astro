---
import Layout from '../layouts/Layout.astro';
const params = Astro.url.searchParams;
const enviado = params.get('enviado') === '1';
const error   = params.get('error') === '1';
---

<Layout title="Contacto">

  <!-- BREADCRUMB -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-5 py-3 flex items-center gap-2 text-sm text-gray-500">
      <a href="/" class="hover:text-primary transition">Inicio</a>
      <span>/</span>
      <span class="text-gray-800 font-medium">Contacto</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-[#011f52] py-16 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 70% 50%, #F05A1A 0%, transparent 60%)"></div>
    <div class="max-w-4xl mx-auto px-5 text-center relative">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-blue-300 bg-white/10 px-3 py-1 rounded-full mb-5">Contáctanos</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
        ¿Cómo podemos ayudarte?
      </h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto">
        Escríbenos o llámanos. Estamos disponibles para asesorarte en remates, ventas y gestión de activos en todo Chile.
      </p>
    </div>
  </section>

  <!-- CONTENIDO PRINCIPAL -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-5 grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- FORMULARIO -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
        <h2 class="text-2xl font-bold text-[#011f52] mb-2">Envíanos un mensaje</h2>
        <p class="text-gray-500 text-sm mb-6">Responderemos a la brevedad posible.</p>

        {enviado && (
          <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-4 py-3 text-sm text-center mb-4">
            ✅ ¡Mensaje enviado! Te contactaremos pronto.
          </div>
        )}
        {error && (
          <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm text-center mb-4">
            ❌ Hubo un error al enviar. Intenta nuevamente o escríbenos directamente.
          </div>
        )}

        <form action="/mail.php" method="POST" class="flex flex-col gap-4">

          <!-- Nombre -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="nombre">Nombre completo *</label>
            <input id="nombre" name="nombre" type="text" required placeholder="Ej: Juan Pérez"
              class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#012A6C]/30 focus:border-[#012A6C] transition" />
          </div>

          <!-- Email -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="email">Correo electrónico *</label>
            <input id="email" name="email" type="email" required placeholder="tucorreo@email.com"
              class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#012A6C]/30 focus:border-[#012A6C] transition" />
          </div>

          <!-- Teléfono -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="telefono">Teléfono</label>
            <input id="telefono" name="telefono" type="tel" placeholder="+56 9 1234 5678"
              class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#012A6C]/30 focus:border-[#012A6C] transition" />
          </div>

          <!-- Asunto -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="asunto">Asunto</label>
            <select id="asunto" name="asunto"
              class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#012A6C]/30 focus:border-[#012A6C] transition bg-white">
              <option value="">Selecciona un asunto</option>
              <option>Consulta sobre vehículo</option>
              <option>Consulta sobre propiedad</option>
              <option>Participar en un remate</option>
              <option>Vender un bien</option>
              <option>Información general</option>
              <option>Otro</option>
            </select>
          </div>

          <!-- Mensaje -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="mensaje">Mensaje *</label>
            <textarea id="mensaje" name="mensaje" required rows="4" placeholder="Escribe tu consulta aquí..."
              class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#012A6C]/30 focus:border-[#012A6C] transition resize-none"></textarea>
          </div>

          <!-- Submit -->
          <button type="submit"
            class="bg-[#012A6C] hover:bg-[#011f52] text-white font-bold px-6 py-3 rounded-xl transition flex items-center justify-center gap-2 mt-1">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Enviar mensaje
          </button>

          <!-- Mensajes de estado -->
          <div id="form-success" class="hidden bg-green-50 border border-green-200 text-green-700 rounded-xl px-4 py-3 text-sm text-center">
            ✅ ¡Mensaje enviado! Te contactaremos pronto.
          </div>
          <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm text-center">
            ❌ Hubo un error. Por favor intenta nuevamente.
          </div>
        </form>
      </div>

      <!-- DATOS + HORARIO -->
      <div class="flex flex-col gap-6">

        <!-- Datos de contacto -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-7">
          <h2 class="text-xl font-bold text-[#011f52] mb-5">Información de contacto</h2>
          <div class="flex flex-col gap-4">

            <a href="tel:+56975884719" class="flex items-start gap-4 group">
              <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-[#012A6C] transition">
                <svg class="w-5 h-5 text-[#012A6C] group-hover:text-white transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold mb-0.5">Teléfono 1</p>
                <p class="text-gray-800 font-medium group-hover:text-[#012A6C] transition">+56 9 7588 4719</p>
              </div>
            </a>

            <a href="tel:+56950119127" class="flex items-start gap-4 group">
              <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-[#012A6C] transition">
                <svg class="w-5 h-5 text-[#012A6C] group-hover:text-white transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold mb-0.5">Teléfono 2</p>
                <p class="text-gray-800 font-medium group-hover:text-[#012A6C] transition">+56 9 5011 9127</p>
              </div>
            </a>

            <a href="mailto:contacto@rematesbipro.cl" class="flex items-start gap-4 group">
              <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-[#012A6C] transition">
                <svg class="w-5 h-5 text-[#012A6C] group-hover:text-white transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold mb-0.5">Email</p>
                <p class="text-gray-800 font-medium group-hover:text-[#012A6C] transition">contacto@rematesbipro.cl</p>
              </div>
            </a>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-[#012A6C]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold mb-0.5">Dirección</p>
                <p class="text-gray-800 font-medium">Av. Alemania 1550</p>
                <p class="text-gray-500 text-sm">Los Ángeles, Región del Biobío</p>
              </div>
            </div>

          </div>
        </div>

        <!-- Horario -->
        <div class="bg-[#011f52] rounded-2xl p-7 text-white">
          <h2 class="text-xl font-bold mb-5 flex items-center gap-2">
            <svg class="w-5 h-5 text-[#F05A1A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Horario de atención
          </h2>
          <div class="flex flex-col gap-2.5 text-sm">
            {[
              { dia: 'Lunes a Viernes', hora: '09:00 – 18:00' },
              { dia: 'Sábado',          hora: '10:00 – 14:00' },
              { dia: 'Domingo',         hora: 'Cerrado' },
            ].map(h => (
              <div class="flex items-center justify-between border-b border-white/10 pb-2.5 last:border-0 last:pb-0">
                <span class="text-white/70">{h.dia}</span>
                <span class={`font-semibold ${h.hora === 'Cerrado' ? 'text-white/30' : 'text-white'}`}>{h.hora}</span>
              </div>
            ))}
          </div>
          <p class="text-white/40 text-xs mt-4">* También puedes escribirnos fuera de horario y te respondemos al día siguiente hábil.</p>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  // Scroll al aviso de éxito/error
  const msg = document.querySelector('.bg-green-50, .bg-red-50');
  if (msg) msg.scrollIntoView({ behavior: 'smooth', block: 'center' });

  // Prevenir doble envío
  document.querySelector('form')?.addEventListener('submit', function(this: HTMLFormElement) {
    const btn = this.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = 'Enviando...'; }
  });
</script>
